# =============================================================================
# Rattle API — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your setup.
#
#   cp .env.example .env
#
# Never commit the .env file — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Rattle API — Tenant credentials
# ---------------------------------------------------------------------------
# Add one key per tenant. The part after RATTLE_API_KEY_ becomes the tenant
# name (lowercased) used on the CLI:  python main.py <tenant> <command>

RATTLE_API_KEY_PRESSTA=your-api-key-here
# RATTLE_API_KEY_ANOTHER_TENANT=another-key

# ---------------------------------------------------------------------------
# AI Provider selection
# ---------------------------------------------------------------------------
# Choose one: openai | anthropic | ollama | custom
AI_PROVIDER=openai

# ---------------------------------------------------------------------------
# OpenAI / compatible (Azure, vLLM, LM Studio, …)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/
# OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Ollama (local inference)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ---------------------------------------------------------------------------
# Custom HTTP endpoint (must accept OpenAI-shaped JSON)
# ---------------------------------------------------------------------------
# CUSTOM_AI_BASE_URL=https://your-endpoint.example.com
# CUSTOM_AI_API_KEY=optional-bearer-token
# CUSTOM_AI_MODEL=default
